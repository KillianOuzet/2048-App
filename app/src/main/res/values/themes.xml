    <!--                     THÈME CLAIR                            -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <style name="Theme.App.Light" parent="Theme.App.Base">

        <!-- ── Couleurs Material Components standard ── -->
        <item name="colorPrimary">@color/light_primary</item>
        <item name="colorPrimaryVariant">@color/light_primary2</item>
        <item name="colorSecondary">@color/light_accent</item>
        <item name="colorSecondaryVariant">@color/light_accent</item>
        <item name="android:colorBackground">@color/light_bg</item>
        <item name="colorSurface">@color/light_card</item>
        <item name="colorError">@color/light_danger</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="colorOnBackground">@color/light_text</item>
        <item name="colorOnSurface">@color/light_text</item>
        <item name="colorOnError">@android:color/white</item>
        <item name="android:textColorPrimary">@color/light_text</item>
        <item name="android:textColorSecondary">@color/light_text2</item>
        <item name="android:statusBarColor">@color/light_bg</item>
        <item name="android:navigationBarColor">@color/light_nav</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- ── Attributs personnalisés 2048 ── -->

        <!-- Arrière-plans -->
        <item name="bgColor">@color/light_bg</item>
        <item name="bgColor2">@color/light_bg2</item>
        <item name="bgColor3">@color/light_bg3</item>

        <!-- Cartes -->
        <item name="cardColor">@color/light_card</item>
        <item name="cardColor2">@color/light_card2</item>
        <item name="cardColor3">@color/light_card3</item>

        <!-- Couleurs principales -->
        <item name="primaryColor">@color/light_primary</item>
        <item name="primaryColor2">@color/light_primary2</item>
        <item name="accentColor">@color/light_accent</item>
        <item name="dangerColor">@color/light_danger</item>

        <!-- Textes -->
        <item name="textColor">@color/light_text</item>
        <item name="textColor2">@color/light_text2</item>
        <item name="textColor3">@color/light_text3</item>

        <!-- Bordures -->
        <item name="borderColor">@color/light_border</item>
        <item name="borderColor2">@color/light_border2</item>

        <!-- Grille -->
        <item name="tileBgColor">@color/light_tile_bg</item>

        <!-- Tuiles -->
        <item name="tile2Color">@color/light_tile_2</item>
        <item name="tile4Color">@color/light_tile_4</item>
        <item name="tile8Color">@color/light_tile_8</item>
        <item name="tile16Color">@color/light_tile_16</item>
        <item name="tile32Color">@color/light_tile_32</item>
        <item name="tile64Color">@color/light_tile_64</item>
        <item name="tile128Color">@color/light_tile_128</item>
        <item name="tile256Color">@color/light_tile_256</item>
        <item name="tile512Color">@color/light_tile_512</item>
        <item name="tile1024Color">@color/light_tile_1024</item>
        <item name="tile2048Color">@color/light_tile_2048</item>

        <!-- Texte tuiles -->
        <item name="tileTextDark">@color/light_tile_text_dark</item>
        <item name="tileTextLight">@color/light_tile_text_light</item>

        <!-- Badge -->
        <item name="badgeBgColor">@color/light_badge_bg</item>
        <item name="badgeTextColor">@color/light_badge_text</item>

        <!-- Toggle -->
        <item name="toggleOffColor">@color/light_toggle_off</item>
        <item name="toggleOnColor">@color/light_toggle_on</item>

        <!-- Navigation -->
        <item name="navColor">@color/light_nav</item>
        <item name="navActiveColor">@color/light_nav_active</item>

        <!-- Scrollbar -->
        <item name="scrollbarColor">@color/light_scrollbar</item>

    </style>



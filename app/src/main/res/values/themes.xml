    <!--                    THÈME DE BASE                           -->
    <!--        (attributs Material communs aux 3 thèmes)           -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <style name="Theme.App.Base" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Désactive l'ActionBar par défaut -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <item name="fontFamily">@font/outfit</item>
        <item name="android:fontFamily">@font/outfit</item>
    </style>

    <style name="SliderLabelPrimary" parent="Widget.MaterialComponents.Tooltip">
        <item name="backgroundTint">?attr/primaryColor</item>
        <item name="android:textColor">@color/white</item>
    </style>


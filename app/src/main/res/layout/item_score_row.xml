<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <TextView
        android:id="@+id/tv_rank"
        android:layout_width="22dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="#1"
        android:textColor="?attr/textColor3"
        android:textSize="13sp"
        android:textStyle="bold"
        app:fontFamily="@font/outfit_black" />

    <androidx.cardview.widget.CardView
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="10dp"
        app:cardBackgroundColor="?attr/cardColor2"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp">

        <TextView
            android:id="@+id/tv_avatar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🎮"
            android:textSize="16sp" />

    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_player_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Joueur"
            android:textColor="?attr/textColor"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_game_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="Tuile max : 512 · 200 coups"
            android:textColor="?attr/textColor3"
            android:textSize="10sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12 345"
            android:textColor="?attr/primaryColor"
            android:textSize="14sp"
            android:textStyle="bold"
            app:fontFamily="@font/outfit_light" />

        <TextView
            android:id="@+id/tv_biggest_tile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="512"
            android:textColor="?attr/textColor3"
            android:textSize="10sp" />

    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/bgColor">

    <!-- Toolbar logo + titre -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/game_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/bgColor"
        android:paddingStart="18dp"
        android:paddingTop="8dp"
        android:paddingEnd="18dp"
        android:paddingBottom="28dp"
        app:contentInsetEnd="0dp"
        app:contentInsetStart="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Logo -->
            <TextView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_logo"
                android:gravity="center"
                android:text="2048"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                app:fontFamily="@font/outfit_black" />

            <!-- Titre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:letterSpacing="-0.03"
                android:text="2048"
                android:textColor="?attr/textColor"
                android:textSize="26sp"
                app:fontFamily="@font/outfit_black" />

        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Barre scores + restart -->
    <LinearLayout
        android:id="@+id/score_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/game_toolbar">

        <!-- Cards score à gauche -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.7"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Score actuel -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="0.5"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_score_card"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="10dp"
                android:paddingEnd="18dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.06"
                    android:text="SCORE"
                    android:textColor="?attr/textColor3"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="?attr/primaryColor"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:fontFamily="@font/outfit_extra_bold" />

            </LinearLayout>

            <!-- Meilleur score -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="0.5"
                android:background="@drawable/bg_score_card"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="10dp"
                android:paddingEnd="18dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.06"
                    android:text="MEILLEUR"
                    android:textColor="?attr/textColor3"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_best_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="?attr/textColor"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:fontFamily="@font/outfit_extra_bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- Espace flexible -->
        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.3" />

        <!-- Bouton restart -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_restart"
            android:layout_width="42dp"
            android:layout_height="42dp"
            app:cardBackgroundColor="?attr/cardColor"
            app:cardCornerRadius="11dp"
            app:cardElevation="2dp"
            app:strokeColor="?attr/borderColor2"
            app:strokeWidth="1dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:contentDescription="Recommencer"
                android:src="@drawable/repeat" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Grille carrée -->
    <GridLayout
        android:id="@+id/game_grid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="18dp"
        android:background="@drawable/bg_grid"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/score_bar"
        app:layout_constraintVertical_bias="0.5" />

</androidx.constraintlayout.widget.ConstraintLayout>
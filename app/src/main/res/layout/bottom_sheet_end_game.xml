<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/cardColor"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="16dp"
    android:paddingEnd="24dp"
    android:paddingBottom="36dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="22dp"
        android:background="?attr/borderColor2" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_end_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉"
            android:textSize="46sp" />

        <TextView
            android:id="@+id/tv_end_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:letterSpacing="-0.02"
            android:text="Félicitations !"
            android:textColor="?attr/primaryColor"
            android:textSize="26sp"
            app:fontFamily="@font/outfit_black" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_end_score_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="18 432"
                android:textColor="?attr/textColor"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="pts"
                android:textColor="?attr/textColor3"
                android:textSize="13sp"
                android:textStyle="bold"
                app:fontFamily="@font/outfit_semi_bold" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_end_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="50dp"
            app:cardElevation="0dp"
            app:contentPaddingBottom="4dp"
            app:contentPaddingLeft="12dp"
            app:contentPaddingRight="12dp"
            app:contentPaddingTop="4dp"
            app:strokeWidth="1dp">

            <TextView
                android:id="@+id/tv_end_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ Nouveau meilleur score !"
                android:textSize="11sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:background="?attr/borderColor2" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:letterSpacing="0.08"
        android:text="TON PSEUDO"
        android:textColor="?attr/textColor3"
        android:textSize="11sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        app:boxBackgroundColor="?attr/bgColor"
        app:boxCornerRadiusBottomEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusTopStart="14dp"
        app:boxStrokeColor="?attr/primaryColor"
        app:hintEnabled="false">

        <androidx.appcompat.widget.AppCompatAutoCompleteTextView
            android:id="@+id/input_pseudo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="👤 Entre ton pseudo..."
            android:inputType="textPersonName"
            android:maxLines="1"
            android:padding="16dp"
            android:textColor="?attr/textColor"
            android:textSize="15sp"
            android:completionThreshold="1"
            android:dropDownVerticalOffset="4dp"
            app:fontFamily="@font/outfit_semi_bold" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save_score"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="14dp"
        android:text="💾 Enregistrer le score"
        android:textSize="16sp"
        app:cornerRadius="16dp"
        app:fontFamily="@font/outfit_bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_restart_only"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Pas maintenant"
        android:textColor="?attr/textColor2"
        app:fontFamily="@font/outfit_semi_bold" />

</LinearLayout>
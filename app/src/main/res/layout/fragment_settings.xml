<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="18dp"
    android:paddingEnd="18dp">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/settings_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:contentInsetStart="0dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardBackgroundColor="?cardColor"
            app:cardCornerRadius="12dp"
            app:strokeColor="?borderColor2"
            app:strokeWidth="1dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="23dp"
                android:layout_gravity="center"
                android:contentDescription="Icon engrenage"
                android:src="@drawable/gear" />

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Réglages"
                android:textColor="?textColor"
                android:textSize="@dimen/text_page_title"
                app:fontFamily="@font/outfit_black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Personnaliser l'expérience"
                android:textColor="?textColor3"
                app:fontFamily="@font/outfit_thin" />
        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/settings_toolbar"
        android:layout_marginTop="15dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:letterSpacing="0.12"
                android:text="Apparence"
                android:textAllCaps="true"
                android:textColor="?textColor3"
                app:fontFamily="@font/outfit_bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                app:cardBackgroundColor="?cardColor"
                app:cardCornerRadius="12dp"
                app:strokeColor="?borderColor2"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingTop="15dp"
                    android:paddingBottom="15dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="15dp"
                        android:text="Thème"
                        android:textColor="?textColor2"
                        app:fontFamily="@font/outfit_bold" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/themeToggleGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginRight="15dp"
                        app:checkedButton="@+id/btnThemeLight"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnThemeLight"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="☀️ Clair"
                            android:textSize="@dimen/text_btn_theme"
                            app:cornerRadius="12dp"
                            app:fontFamily="@font/outfit_bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnThemeDark"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🌙 Sombre"
                            android:textSize="@dimen/text_btn_theme"
                            app:cornerRadius="12dp"
                            app:fontFamily="@font/outfit_bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnThemeColor"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🎨 Coloré"
                            android:textSize="@dimen/text_btn_theme"
                            app:cornerRadius="12dp"
                            app:fontFamily="@font/outfit_bold" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="1sp"
                        android:layout_marginTop="5dp"
                        android:layout_marginBottom="5dp"
                        app:dividerColor="?borderColor2" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginRight="15dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Animations des tuiles"
                                android:textColor="?textColor"
                                android:textSize="@dimen/text_settings_title"
                                app:fontFamily="@font/outfit_semi_bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Effets de glissement et de fusion"
                                android:textColor="?textColor3"
                                app:fontFamily="@font/outfit_thin" />

                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_animation_tuiles"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:thumbTint="@color/white"
                            app:trackTint="@color/switch_track_selector" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="15dp"
                android:letterSpacing="0.12"
                android:text="Son &amp; Musique"
                android:textAllCaps="true"
                android:textColor="?textColor3"
                app:fontFamily="@font/outfit_bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                app:cardBackgroundColor="?cardColor"
                app:cardCornerRadius="12dp"
                app:strokeColor="?borderColor2"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingTop="15dp"
                    android:paddingBottom="15dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginRight="15dp"
                        android:layout_marginBottom="15dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Musique de fond"
                                android:textColor="?textColor"
                                android:textSize="@dimen/text_settings_title"
                                app:fontFamily="@font/outfit_semi_bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ambiance sonore pendant le jeu"
                                android:textColor="?textColor3"
                                app:fontFamily="@font/outfit_thin" />

                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_musique_de_fond"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:thumbTint="@color/white"
                            app:trackTint="@color/switch_track_selector" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginRight="15dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎵 Volume musique"
                            android:textColor="?textColor"
                            android:textSize="@dimen/text_settings_title"
                            app:fontFamily="@font/outfit_semi_bold" />

                        <TextView
                            android:id="@+id/text_volume"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="100%"
                            android:textAlignment="textEnd"
                            android:textColor="?primaryColor"
                            android:textSize="@dimen/text_settings_title" />

                    </LinearLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_volume_musique"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stepSize="1.0"
                        android:value="100.0"
                        android:valueFrom="0.0"

                        android:valueTo="100.0"
                        app:labelStyle="@style/SliderLabelPrimary"
                        app:thumbColor="@color/white"
                        app:trackColor="?primaryColor" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>
</RelativeLayout>
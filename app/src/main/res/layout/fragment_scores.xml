<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="18dp"
    android:paddingEnd="18dp">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/scores_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:contentInsetStart="0dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardBackgroundColor="?cardColor"
            app:cardCornerRadius="12dp"
            app:strokeColor="?borderColor2"
            app:strokeWidth="1dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:contentDescription="Icon trophée"
                android:src="@drawable/trophy" />

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scores"
                android:textColor="?textColor"
                android:textSize="@dimen/text_page_title"
                app:fontFamily="@font/outfit_black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Meilleurs scores locaux"
                android:textColor="?textColor3"
                app:fontFamily="@font/outfit_thin" />

        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/scores_toolbar"
        android:layout_marginTop="15dp"
        android:clipToPadding="false"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="?cardColor"
                app:cardCornerRadius="12dp"
                app:strokeColor="?borderColor2"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleGroupModeScores"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginRight="15dp"
                        app:checkedButton="@+id/toggleButtonClassiqueScores"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/toggleButtonClassiqueScores"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Classique"
                            android:textSize="@dimen/text_btn_theme"
                            app:cornerRadius="12dp"
                            app:fontFamily="@font/outfit_bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/toggleButtonMultijoueurScores"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Multijoueur"
                            android:textSize="@dimen/text_btn_theme"
                            app:cornerRadius="12dp"
                            app:fontFamily="@font/outfit_bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/toggleButtonDefiScores"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Défi"
                            android:textSize="@dimen/text_btn_theme"
                            app:cornerRadius="12dp"
                            app:fontFamily="@font/outfit_bold" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="1sp"
                        android:layout_marginTop="5dp"
                        android:layout_marginBottom="5dp"
                        app:dividerColor="?borderColor2" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleGroupTailleScores"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginRight="15dp"
                        android:layout_marginBottom="5dp"
                        app:checkedButton="@+id/toggleButton4x4Scores"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/toggleButton3x3Scores"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="3×3"
                            android:textSize="@dimen/text_btn_theme"
                            app:cornerRadius="12dp"
                            app:fontFamily="@font/outfit_bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/toggleButton4x4Scores"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="4×4"
                            android:textSize="@dimen/text_btn_theme"
                            app:cornerRadius="12dp"
                            app:fontFamily="@font/outfit_bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/toggleButton5x5Scores"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="5×5"
                            android:textSize="@dimen/text_btn_theme"
                            app:cornerRadius="12dp"
                            app:fontFamily="@font/outfit_bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/toggleButton6x6Scores"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="6×6"
                            android:textSize="@dimen/text_btn_theme"
                            app:cornerRadius="12dp"
                            app:fontFamily="@font/outfit_bold" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/textviewClassmentsTitre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="9dp"
                android:letterSpacing="0.12"
                android:text="CLASSEMENT LOCAL"
                android:textColor="?attr/textColor3"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_scores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_card"
                android:clipToPadding="true"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <LinearLayout
                android:id="@+id/layout_empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="44dp"
                android:layout_marginBottom="30dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤷"
                    android:textSize="48sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Aucun score pour le moment"
                    android:textColor="?attr/textColor3"
                    android:textSize="16sp"
                    app:fontFamily="@font/outfit_regular" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lancez une partie pour apparaître ici !"
                    android:textColor="?attr/textColor3"
                    android:textSize="12sp"
                    app:fontFamily="@font/outfit_thin" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset_scores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🗑 Réinitialiser le classement"
                android:textColor="?attr/dangerColor"
                android:textSize="12sp"
                android:visibility="gone"
                app:backgroundTint="?attr/cardColor"
                app:cornerRadius="14dp"
                app:icon="@null"
                app:strokeColor="?attr/dangerColor"
                app:strokeWidth="1.5dp" />

        </LinearLayout>

    </ScrollView>

</RelativeLayout>